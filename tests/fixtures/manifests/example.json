{
  "version": 1,
  "name": "example-offline-benchmark",
  "media_root": "data/benchmark_media",
  "notes": "媒体文件不入库；本机缺失时应 dry-run 跳过。合成预测见同目录 predictions 示例。",
  "diarizers": ["wespeaker", "campplus"],
  "samples": [
    {
      "sample_id": "synth_asr_01",
      "scenario": "single_speaker",
      "description": "合成 ASR 样本（无需真实音频即可用 predictions 评估）",
      "media_path": "synth_asr_01.wav",
      "optional": true,
      "tags": ["asr", "synthetic"],
      "annotations": {
        "transcript": [
          {"start_ms": 0, "end_ms": 2000, "text": "我们先看课板上的公式"}
        ],
        "speaker_turns": [
          {"start_ms": 0, "end_ms": 2000, "speaker_id": "spk_0"}
        ]
      }
    },
    {
      "sample_id": "synth_diar_02",
      "scenario": "two_speaker",
      "description": "双人说话人分离合成标注",
      "media_path": "synth_diar_02.wav",
      "optional": true,
      "tags": ["diarization", "synthetic"],
      "annotations": {
        "speaker_turns": [
          {"start_ms": 0, "end_ms": 1000, "speaker_id": "A"},
          {"start_ms": 1000, "end_ms": 2500, "speaker_id": "B"},
          {"start_ms": 2500, "end_ms": 4000, "speaker_id": "A"}
        ]
      }
    },
    {
      "sample_id": "synth_board_left",
      "scenario": "board_left",
      "description": "左侧课板区域 IoU / 去重 / OCR",
      "media_path": "synth_board_left.mp4",
      "optional": true,
      "tags": ["board", "ocr", "synthetic"],
      "annotations": {
        "board_regions": [
          {"x": 10, "y": 20, "width": 400, "height": 300, "timestamp_ms": 0}
        ],
        "board_pages": [
          {
            "version_id": "page_1",
            "start_ms": 0,
            "end_ms": 5000,
            "text": "第一章 引入",
            "region": {"x": 10, "y": 20, "width": 400, "height": 300}
          },
          {
            "version_id": "page_2",
            "start_ms": 5000,
            "end_ms": 10000,
            "text": "第二章 案例"
          }
        ],
        "ocr_text": "第一章引入第二章案例"
      }
    },
    {
      "sample_id": "real_classroom_placeholder",
      "scenario": "end_to_end",
      "description": "真实课堂视频占位：请把文件放到 media_root 并填写标注",
      "media_path": "classroom/lesson_01.mp4",
      "optional": true,
      "tags": ["e2e", "needs_local_media"],
      "annotations": {}
    }
  ]
}
