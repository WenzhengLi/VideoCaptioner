{
  "$defs": {
    "FidelityFieldReview": {
      "additionalProperties": false,
      "properties": {
        "field": {
          "title": "Field",
          "type": "string"
        },
        "status": {
          "enum": [
            "supported",
            "partially_supported",
            "unsupported",
            "misattributed",
            "missing_condition"
          ],
          "title": "Status",
          "type": "string"
        },
        "issue": {
          "default": "",
          "title": "Issue",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "required_action": {
          "enum": [
            "keep",
            "delete",
            "downgrade",
            "reattribute",
            "rewrite_from_evidence"
          ],
          "title": "Required Action",
          "type": "string"
        }
      },
      "required": [
        "field",
        "status",
        "required_action"
      ],
      "title": "FidelityFieldReview",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "pipeline_version": {
      "default": "afeng-method-v001",
      "title": "Pipeline Version",
      "type": "string"
    },
    "prompt_version": {
      "default": "mimo-method-v002",
      "title": "Prompt Version",
      "type": "string"
    },
    "course_id": {
      "title": "Course Id",
      "type": "string"
    },
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "knowledge_id": {
      "title": "Knowledge Id",
      "type": "string"
    },
    "revision_number": {
      "default": 0,
      "maximum": 2,
      "minimum": 0,
      "title": "Revision Number",
      "type": "integer"
    },
    "audit_result": {
      "enum": [
        "pass",
        "revise",
        "reject"
      ],
      "title": "Audit Result",
      "type": "string"
    },
    "fidelity_score": {
      "maximum": 100,
      "minimum": 0,
      "title": "Fidelity Score",
      "type": "number"
    },
    "field_reviews": {
      "items": {
        "$ref": "#/$defs/FidelityFieldReview"
      },
      "title": "Field Reviews",
      "type": "array"
    },
    "unsupported_additions": {
      "items": {
        "type": "string"
      },
      "title": "Unsupported Additions",
      "type": "array"
    },
    "misattributed_claims": {
      "items": {
        "type": "string"
      },
      "title": "Misattributed Claims",
      "type": "array"
    },
    "missing_course_conditions": {
      "items": {
        "type": "string"
      },
      "title": "Missing Course Conditions",
      "type": "array"
    },
    "invalid_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Invalid Evidence Ids",
      "type": "array"
    },
    "external_knowledge_detected": {
      "items": {
        "type": "string"
      },
      "title": "External Knowledge Detected",
      "type": "array"
    },
    "revision_instructions": {
      "items": {
        "type": "string"
      },
      "title": "Revision Instructions",
      "type": "array"
    },
    "release_allowed": {
      "default": false,
      "title": "Release Allowed",
      "type": "boolean"
    }
  },
  "required": [
    "course_id",
    "case_id",
    "knowledge_id",
    "audit_result",
    "fidelity_score",
    "field_reviews"
  ],
  "title": "FidelityAudit",
  "type": "object"
}