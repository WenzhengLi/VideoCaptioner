filters:
  and:
    - 'record_type == "ob"'
    - 'course_id == "C027"'
views:
  - type: table
    name: C027回答分类
    order:
      - note.object_id
      - file.name
      - note.female_line
      - note.reply_directions
      - note.example_count
      - note.approval_status
properties:
  object_id:
    displayName: OB编号
  female_line:
    displayName: 女生原话
  reply_directions:
    displayName: 回答分类
  example_count:
    displayName: 示例数
  approval_status:
    displayName: 状态
