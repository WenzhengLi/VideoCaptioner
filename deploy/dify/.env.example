# Copy to D:\Dev\dify-deploy\repo\docker\.env after bootstrap.
# DO NOT put real API keys in this file or commit a filled .env.

# Pinned official Dify release (non-prerelease)
DIFY_GIT_TAG=1.15.0

# Deploy roots (local only)
DIFY_DEPLOY_ROOT=D:\Dev\dify-deploy
DIFY_REPO_DIR=D:\Dev\dify-deploy\repo
COMPOSE_PROJECT_NAME=dify

# Avoid colliding with other local HTTP services if needed
EXPOSE_NGINX_PORT=3080
EXPOSE_NGINX_SSL_PORT=3443

# Dify API sync — values live in D:\Dev\dify-deploy\secrets\dify-runtime.env
# Never commit real values.
DIFY_BASE_URL=http://127.0.0.1:3080/v1
DIFY_API_KEY=
DIFY_DATASET_ID=

# After gate-passed final bundle (currently afeng-release-v002.5):
#   .\.venv\Scripts\python.exe -m course_video_analyzer.knowledge.cli dify-sync-markdown `
#     --markdown-root data/dify/afeng-release-v002.5/documents `
#     --map-path data/dify/document-map.json `
#     --poll-indexing
# Dry-run (no API keys required):
#   .\.venv\Scripts\python.exe -m course_video_analyzer.knowledge.cli dify-sync-markdown `
#     --markdown-root data/dify/afeng-release-v002.5/documents `
#     --map-path data/dify/document-map.json `
#     --dry-run
